# CryptoLogin Configuration

# Security
CRYPTOLOGIN_SECRET_KEY=your-super-secret-key-change-in-production
FLASH512_VANGUARD_CORE=your-super-secret-FLASH512-VANGUARD-key-change-in-production

# Application
DEBUG=False
HOST=0.0.0.0
PORT=8000
API_PREFIX=/api/v1

# Database
DATABASE_URL=sqlite:///cryptologin.db

# Session
SESSION_DURATION_HOURS=24

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000